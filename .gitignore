# Node.js dependencies
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Environment variables (never commit secrets!)
.env
.env.local
.env.*.local

# Prisma
prisma/dev.db        # local SQLite (optional)
prisma/migrations/*.sql  # optional: raw migration files
prisma/.env          # if you ever put separate env for Prisma

# Logs
logs/
*.log
*.log.*
pids/
*.pid
*.seed

# Build / transpiled output
dist/
build/

# OS files
.DS_Store
Thumbs.db

# IDE / editor configs
.vscode/
.idea/
*.sublime-workspace
*.sublime-project

# Redis / BullMQ temporary files (if any)
*.rdb
*.aof
bull-data/           # if you persist local BullMQ job data

# Test coverage
coverage/

# Optional: ignore Docker artifacts
docker-compose.override.yml
*.docker

# Optional: ignore backup / temp files
*.bak
*.tmp
/generated/
generated/

